  # Agent model overrides (optional — defaults to each agent's built-in default)
  CLAUDE_MODEL=
  CURSOR_MODEL=
  CODEX_MODEL=

  # Additional CLI args appended to agent commands (optional)
  CLAUDE_ADDITIONAL_ARGS=
  CURSOR_ADDITIONAL_ARGS=
  CODEX_ADDITIONAL_ARGS=

  # Timeout settings (optional)
  AGENT_TIMEOUT_MS=300000
  AGENT_IDLE_TIMEOUT_MS=120000

  # Bot auth isolation (optional — when set, agents authenticate as the bot account)
  EVAL_GH_TOKEN=
  EVAL_GIT_NAME=skills-evals-bot
  EVAL_GIT_EMAIL=skills-evals-bot@users.noreply.github.com