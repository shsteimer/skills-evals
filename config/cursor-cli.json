{
  "permissions": {
    "allow": [
      "Shell(npm)", "Shell(npx)", "Shell(node)",
      "Shell(git)", "Shell(gh)",
      "Shell(curl)", "Shell(cat)", "Shell(ls)", "Shell(cd)", "Shell(pwd)",
      "Shell(echo)", "Shell(grep)", "Shell(find)", "Shell(mkdir)", "Shell(touch)",
      "Shell(head)", "Shell(tail)", "Shell(wc)", "Shell(sort)", "Shell(sed)",
      "Shell(awk)", "Shell(which)", "Shell(cp)", "Shell(mv)", "Shell(rm)",
      "Shell(chmod)", "Shell(diff)", "Shell(open)", "Shell(env)", "Shell(printenv)",
      "Shell(true)", "Shell(false)", "Shell(test)",
      "Read(**)", "Write(**)", "WebFetch(*)"
    ],
    "deny": [
      "Shell(git push --force*)", "Shell(git push -f*)",
      "Shell(gh repo delete*)", "Shell(gh pr merge*)", "Shell(gh pr close*)", "Shell(gh issue close*)"
    ]
  }
}
